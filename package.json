{
  "name": "@ds-mo/icons",
  "version": "0.7.4",
  "description": "IcoMo — 422 SVG icons (390 system icons + 32 country flags) as tree-shakeable React components, framework-agnostic SVG strings, TypeScript definitions, and SVG sprite",
  "keywords": [
    "icons",
    "svg",
    "react",
    "icon-library",
    "design-system",
    "tree-shakeable",
    "typescript",
    "flags",
    "country-flags",
    "compomo",
    "ds-mo"
  ],
  "homepage": "https://zainadeel.github.io/icomo/",
  "bugs": "https://github.com/zainadeel/icomo/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/zainadeel/icomo.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./icons/*": {
      "import": "./dist/icons/*.mjs",
      "types": "./dist/icons/*.d.ts"
    },
    "./flags": {
      "import": "./dist/flags/index.mjs",
      "types": "./dist/flags/index.d.ts"
    },
    "./flags/*": {
      "import": "./dist/flags/*.mjs",
      "types": "./dist/flags/*.d.ts"
    },
    "./svg": {
      "import": "./dist/svg/index.mjs",
      "types": "./dist/svg/index.d.ts"
    },
    "./svg/flags": {
      "import": "./dist/svg/flags/index.mjs",
      "types": "./dist/svg/flags/index.d.ts"
    },
    "./svg/flags/*": {
      "import": "./dist/svg/flags/*.mjs",
      "types": "./dist/svg/flags/*.d.ts"
    },
    "./svg/*": {
      "import": "./dist/svg/*.mjs",
      "types": "./dist/svg/*.d.ts"
    },
    "./sprite": "./dist/sprite.svg",
    "./meta": {
      "import": "./dist/meta.mjs",
      "types": "./dist/meta.d.ts",
      "default": "./dist/meta.json"
    },
    "./meta.json": "./dist/meta.json",
    "./createIcon": {
      "import": "./dist/createIcon.mjs",
      "types": "./dist/createIcon.d.ts"
    },
    "./createFlagIcon": {
      "import": "./dist/createFlagIcon.mjs",
      "types": "./dist/createFlagIcon.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:docs": "node scripts/build-docs.mjs",
    "dev": "node scripts/build.mjs --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "chokidar": "^5.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
